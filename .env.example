# ==========================================
# BACKEND CONFIGURATION (server/.env)
# ==========================================
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/last_mile_delivery?retryWrites=true&w=majority
JWT_SECRET=your_jwt_signing_secret_key_string
JWT_EXPIRE=30d
NODE_ENV=production

# Nodemailer SMTP Configuration
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user_key
SMTP_PASS=your_smtp_pass_key
SMTP_FROM="Last-Mile Delivery" <noreply@lastmile.com>

# ==========================================
# FRONTEND CONFIGURATION (client/.env)
# ==========================================
# (Optional) If you deploy frontend and backend on separate domains:
# VITE_API_URL=https://your-api-domain.com
